# OpsPilot environment variables template
# Copy this to .env and fill in your keys
# .env is gitignored — never commit the real file

APP_NAME=OpsPilot
PORT=8000
AI_MODE=llm

# LLM API Keys — Gemini is tried first, then Groq, then Mistral
# Get free keys at:
#   Gemini:  https://aistudio.google.com/app/apikey
#   Groq:    https://console.groq.com/keys
#   Mistral: https://console.mistral.ai/api-keys
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Database path
# Leave blank for local dev (uses system temp folder)
# Set to /data/internalops.db for Docker / Railway / Render with persistent storage
INTERNALOPS_DB=
